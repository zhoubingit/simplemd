{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "simplemd",
  "version": "1.0.0",
  "identifier": "com.dell.simplemd",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "startup",
        "title": "simplemd",
        "url": "splash.html",
        "width": 420,
        "height": 260,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "focus": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "backgroundColor": "#f4f5f7"
      },
      {
        "label": "main",
        "title": "simplemd",
        "width": 800,
        "height": 600,
        "center": true,
        "focus": false,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
